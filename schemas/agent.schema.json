{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nina.dev/schemas/agent.schema.json",
  "title": "NINA Site Contract (agent.json)",
  "type": "object",
  "required": ["site", "version", "pages", "actions", "embed"],
  "additionalProperties": false,
  "properties": {
    "site": {
      "type": "object",
      "required": ["id", "name", "baseUrl"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,62}$" },
        "name": { "type": "string", "minLength": 1 },
        "baseUrl": { "type": "string", "format": "uri" },
        "locales": { "type": "array", "items": { "type": "string" } },
        "markets": { "type": "array", "items": { "type": "string" } },
        "defaultMarket": { "type": "string" },
        "country": { "type": "string" }
      }
    },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "description": { "type": "string" },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/page" }
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/action" }
    },
    "selectors": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "auth": { "$ref": "#/$defs/auth" },
    "risk": { "$ref": "#/$defs/risk" },
    "embed": { "$ref": "#/$defs/embed" },
    "vocabulary": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "routes": {
      "type": "array",
      "items": { "$ref": "#/$defs/route" }
    },
    "apis": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/apiGroup" }
    },
    "signals": { "$ref": "#/$defs/signals" }
  },
  "$defs": {
    "route": {
      "type": "object",
      "required": ["pattern", "pageId"],
      "additionalProperties": false,
      "properties": {
        "pattern": { "type": "string", "minLength": 1 },
        "pageId": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
      }
    },
    "page": {
      "type": "object",
      "required": ["id", "urlPattern"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "urlPattern": { "type": "string", "minLength": 1 },
        "label": { "type": "string" },
        "actions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "action": {
      "type": "object",
      "required": ["id", "description", "parameters", "execute"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "description": { "type": "string", "minLength": 3 },
        "parameters": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/param" }
        },
        "risk": { "type": "string", "enum": ["low", "medium", "high"], "default": "low" },
        "requiresAuth": { "type": "boolean", "default": false },
        "availableOn": {
          "type": "array",
          "items": { "type": "string" }
        },
        "execute": { "$ref": "#/$defs/execute" }
      }
    },
    "param": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["string", "number", "boolean", "integer"] },
        "required": { "type": "boolean", "default": false },
        "description": { "type": "string" },
        "enum": { "type": "array" }
      }
    },
    "apiGroup": {
      "type": "object",
      "required": ["baseUrl"],
      "additionalProperties": false,
      "properties": {
        "baseUrl": { "type": "string", "minLength": 1 },
        "description": { "type": "string" }
      }
    },
    "apiRef": {
      "type": "object",
      "required": ["method", "path"],
      "additionalProperties": false,
      "properties": {
        "apiId": { "type": "string" },
        "method": { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
        "path": { "type": "string", "minLength": 1 },
        "paramMap": { "type": "object", "additionalProperties": { "type": "string" } },
        "bodyTemplate": { "type": "object" },
        "responseMap": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },
    "execute": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["dom", "api", "hybrid", "message"] },
        "runtime": { "type": "string", "enum": ["server", "browser", "dom_only"] },
        "apiRef": { "$ref": "#/$defs/apiRef" },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/$defs/step" },
          "default": []
        }
      }
    },
    "step": {
      "type": "object",
      "required": ["op"],
      "additionalProperties": true,
      "properties": {
        "op": {
          "type": "string",
          "enum": ["click", "fill", "scroll", "navigate", "api_call", "wait", "toast", "show_message"]
        },
        "selector": { "type": "string" },
        "selectorId": { "type": "string" },
        "param": { "type": "string" },
        "value": { "type": "string" },
        "url": { "type": "string" },
        "method": { "type": "string" },
        "body": { "type": "object" },
        "paramMap": { "type": "object" },
        "ms": { "type": "integer", "minimum": 0 },
        "message": { "type": "string" },
        "level": { "type": "string" }
      }
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "loginUrl": { "type": "string" },
        "sessionIndicator": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["cookie", "localStorage", "selector"] },
            "name": { "type": "string" },
            "selector": { "type": "string" }
          }
        },
        "gatedActions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "confirmActions": { "type": "array", "items": { "type": "string" } },
        "blockActions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "embed": {
      "type": "object",
      "required": ["panel"],
      "additionalProperties": false,
      "properties": {
        "panel": { "type": "string", "enum": ["left", "right"] },
        "apiBase": { "type": "string" },
        "manifestUrl": { "type": "string", "format": "uri" }
      }
    },
    "signals": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "productDetail": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "hasSizeOptions": { "type": "boolean" },
            "sizeLabels": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
